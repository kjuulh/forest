{
  "db_name": "PostgreSQL",
  "query": "\n                SELECT\n                    a.id,\n                    a.artifact_id,\n                    a.slug,\n                    a.metadata,\n                    a.source,\n                    a.context,\n                    a.project_id,\n                    a.created,\n                    p.organisation as organisation,\n                    p.project as project\n                FROM annotations a\n                JOIN projects p ON a.project_id = p.id\n                WHERE\n                    slug = $1\n            ",

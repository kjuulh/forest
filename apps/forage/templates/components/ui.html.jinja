{# Shared UI macros for consistent styling across templates.
   Usage: {% from "components/ui.html.jinja" import badge, env_badge, alert, empty_state, pagination, code_block %}
#}

{# ── Badge ─────────────────────────────────────────────────────── #}
{# Renders an inline badge with a color variant.
   Variants: gray (default), green, red, blue, violet, cyan, pink, orange, yellow, amber
   Usage: {{ badge("v1.0.0") }}
          {{ badge("binary", variant="violet") }}
#}
{% macro badge(label, variant="gray") %}
{% set colors = {
    "gray": "bg-gray-100 text-gray-700",
    "green": "bg-green-100 text-green-800",
    "red": "bg-red-100 text-red-800",
    "blue": "bg-blue-100 text-blue-800",
    "violet": "bg-violet-100 text-violet-700",
    "cyan": "bg-cyan-100 text-cyan-700",
    "pink": "bg-pink-100 text-pink-800",
    "orange": "bg-orange-100 text-orange-800",
    "yellow": "bg-yellow-100 text-yellow-800",
    "amber": "bg-amber-100 text-amber-700"
} %}
<span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full {{ colors[variant] | default(colors.gray) }}">{{ label }}</span>
{%- endmacro %}

{# ── Environment badge ─────────────────────────────────────────── #}
{# Renders an environment name with appropriate color.
   Usage: {{ env_badge("production") }}
#}
{% macro env_badge(env) %}
{% if 'prod' in env and 'preprod' not in env %}{% set variant = "pink" %}
{% elif 'preprod' in env or 'pre-prod' in env %}{% set variant = "orange" %}
{% elif 'stag' in env %}{% set variant = "yellow" %}
{% elif 'dev' in env %}{% set variant = "violet" %}
{% elif 'test' in env %}{% set variant = "cyan" %}
{% else %}{% set variant = "gray" %}{% endif %}
{{ badge(env, variant=variant) }}
{%- endmacro %}

{# ── Alert ─────────────────────────────────────────────────────── #}
{# Renders a dismissible alert box.
   Variants: error (red), success (green), info (blue), warning (yellow)
   Usage: {{ alert("Something went wrong", variant="error") }}
#}
{% macro alert(message, variant="error") %}
{% set styles = {
    "error": "bg-red-50 border-red-200 text-red-700",
    "success": "bg-green-50 border-green-200 text-green-700",
    "info": "bg-blue-50 border-blue-200 text-blue-700",
    "warning": "bg-yellow-50 border-yellow-200 text-yellow-700"
} %}
<div class="mb-6 p-4 border rounded-md text-sm {{ styles[variant] | default(styles.error) }}">
    {{ message }}
</div>
{%- endmacro %}

{# ── Empty state ───────────────────────────────────────────────── #}
{# Renders a centered empty state card.
   Usage: {{ empty_state("No projects yet.", hint="Deploy with forest release create") }}
#}
{% macro empty_state(message, hint="") %}
<div class="p-6 border border-gray-200 rounded-lg text-center">
    <p class="text-gray-600">{{ message }}</p>
    {% if hint %}
    <p class="text-sm text-gray-400 mt-2">{{ hint }}</p>
    {% endif %}
</div>
{%- endmacro %}

{# ── Pagination ────────────────────────────────────────────────── #}
{# Renders prev/next pagination controls.
   Usage: {{ pagination(base_url="/components", page=page, total_pages=total_pages, params={"q": query}) }}
#}
{% macro pagination(base_url, page, total_pages, params={}) %}
{% if total_pages > 1 %}
{% set qs = "?" %}
{% for k, v in params | items %}{% if v %}{% set qs = qs ~ k ~ "=" ~ v ~ "&" %}{% endif %}{% endfor %}
<nav class="mt-8 flex items-center justify-center gap-2">
    {% if page > 1 %}
    <a href="{{ base_url }}{{ qs }}page={{ page - 1 }}" class="px-3 py-1.5 text-sm border border-gray-300 rounded-md hover:border-gray-400">Previous</a>
    {% endif %}
    <span class="text-sm text-gray-500">Page {{ page }} of {{ total_pages }}</span>
    {% if page < total_pages %}
    <a href="{{ base_url }}{{ qs }}page={{ page + 1 }}" class="px-3 py-1.5 text-sm border border-gray-300 rounded-md hover:border-gray-400">Next</a>
    {% endif %}
</nav>
{% endif %}
{%- endmacro %}

{# ── Code block ────────────────────────────────────────────────── #}
{# Renders a dark code block with optional copy button.
   Usage: {{ code_block("forest components add org/name@1.0", copyable=true, id="install") }}
#}
{% macro code_block(content, copyable=false, id="", class="") %}
<div class="bg-gray-950 rounded-md p-3 text-sm font-mono text-gray-300 overflow-x-auto {{ class }} {% if copyable %}relative group{% endif %}">
    <pre{% if id %} id="{{ id }}"{% endif %} class="whitespace-pre">{{ content }}</pre>
    {% if copyable %}
    <button onclick="navigator.clipboard.writeText(document.getElementById('{{ id }}').textContent.trim());this.textContent='Copied!';setTimeout(()=>this.textContent='Copy',1500)" class="absolute top-2 right-2 px-2 py-0.5 text-xs bg-gray-800 text-gray-400 rounded hover:text-white opacity-0 group-hover:opacity-100 transition-opacity">Copy</button>
    {% endif %}
</div>
{%- endmacro %}

{# ── Kind badge ────────────────────────────────────────────────── #}
{# Renders a component kind badge (binary/files).
   Usage: {{ kind_badge("binary") }}
#}
{% macro kind_badge(kind) %}
{% if kind == "binary" %}{{ badge("binary", variant="violet") }}{% else %}{{ badge("files", variant="cyan") }}{% endif %}
{%- endmacro %}

{# ── Visibility badge ──────────────────────────────────────────── #}
{# Renders a public/private visibility indicator.
   Usage: {{ visibility_badge("public") }}
#}
{% macro visibility_badge(visibility) %}
{% if visibility == "public" %}{{ badge("public", variant="green") }}{% else %}{{ badge("private", variant="gray") }}{% endif %}
{%- endmacro %}

{# ── Tool shape badge ──────────────────────────────────────────── #}
{# Renders the artefact-shape badge.
   Accepts the snake_case ToolShape variants (component / hybrid /
   tool_binary / tool_external / unknown).
   Usage: {{ tool_shape_badge("tool_binary") }}
#}
{% macro tool_shape_badge(shape) %}
{% if shape == "hybrid" %}{{ badge("hybrid", variant="pink") }}
{%- elif shape == "tool_binary" %}{{ badge("tool", variant="violet") }}
{%- elif shape == "tool_external" %}{{ badge("tool-ext", variant="cyan") }}
{%- elif shape == "component" %}{{ badge("component", variant="gray") }}
{%- else %}{{ badge("tool", variant="violet") }}{% endif %}
{%- endmacro %}

{# ── Pretty JSON block ─────────────────────────────────────────── #}
{# Renders the server-side-tokenised JSON HTML in a styled <pre> block.
   The `html` argument is the output of pretty_json::tokenize() — already
   HTML-safe and pre-escaped at the Rust layer. The <details> wrapper
   makes the section collapsible.
   Usage: {{ pretty_json_block(manifest_html, title="Manifest") }}
#}
{% macro pretty_json_block(html, title="Manifest", open=false) %}
<details class="border border-gray-200 rounded-lg overflow-hidden"{% if open %} open{% endif %}>
    <summary class="px-4 py-2 text-sm font-medium text-gray-700 cursor-pointer hover:bg-gray-50 select-none">{{ title }}</summary>
    <div class="bg-gray-950 p-4 text-xs font-mono leading-relaxed text-gray-300 overflow-x-auto json-pretty"><pre>{{ html | safe }}</pre></div>
</details>
{%- endmacro %}

{# ── Section heading ───────────────────────────────────────────── #}
{# Renders a page heading with optional action slot.
   Usage: {{ section_heading("Projects") }}
#}
{% macro section_heading(title) %}
<div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl font-bold">{{ title }}</h1>
    {{ caller() if caller is defined }}
</div>
{%- endmacro %}

{# ── About sidebar block (spec 009) ───────────────────────────────
   Renders the blessed project metadata as the topmost item in the
   project / component-detail sidebars. Pass the `project_metadata`
   context computed by the route handler; the macro is a no-op when
   `metadata.has_any` is false. URL fields become target=_blank
   anchors with rel=noopener noreferrer; text fields render as plain
   spans. Icons match the role of each field.
#}
{% macro about_block(metadata) %}
{% if metadata and metadata.has_any %}
<div>
    <h3 class="text-sm font-bold mb-2 flex items-center gap-2">
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        About
    </h3>
    <ul class="space-y-2 text-sm">
        {% if metadata.git_url %}
        <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-gray-400 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            <a href="{{ metadata.git_url }}" target="_blank" rel="noopener noreferrer" class="text-gray-700 hover:text-gray-900 hover:underline break-all">{{ metadata.git_url }}</a>
        </li>
        {% endif %}
        {% if metadata.homepage %}
        <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-gray-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <a href="{{ metadata.homepage }}" target="_blank" rel="noopener noreferrer" class="text-gray-700 hover:text-gray-900 hover:underline break-all">{{ metadata.homepage }}</a>
        </li>
        {% endif %}
        {% if metadata.docs_url %}
        <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-gray-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
            <a href="{{ metadata.docs_url }}" target="_blank" rel="noopener noreferrer" class="text-gray-700 hover:text-gray-900 hover:underline break-all">{{ metadata.docs_url }}</a>
        </li>
        {% endif %}
        {% if metadata.support_url %}
        <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-gray-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
            <a href="{{ metadata.support_url }}" target="_blank" rel="noopener noreferrer" class="text-gray-700 hover:text-gray-900 hover:underline break-all">{{ metadata.support_url }}</a>
        </li>
        {% endif %}
        {% if metadata.domain %}
        <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-gray-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            <span class="text-gray-700">{{ metadata.domain }}</span>
        </li>
        {% endif %}
        {% if metadata.owner %}
        <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-gray-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            <span class="text-gray-700">{{ metadata.owner }}</span>
        </li>
        {% endif %}
    </ul>
</div>
{% endif %}
{%- endmacro %}

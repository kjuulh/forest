{# Settings sidebar navigation for org settings pages.
   Usage: {% from "components/settings_sidebar.html.jinja" import settings_sidebar %}
          {{ settings_sidebar(org_name, "members") }}
#}
{% macro settings_sidebar(org_name, active_section) %}
<nav class="w-48 shrink-0 hidden md:block">
    <ul class="space-y-0.5">
        <li>
            <a href="/orgs/{{ org_name }}/settings" class="block px-3 py-1.5 text-sm rounded-md {% if active_section == 'general' %}bg-gray-100 text-gray-900 font-medium{% else %}text-gray-600 hover:text-gray-900 hover:bg-gray-50{% endif %}">General</a>
        </li>
        <li>
            <a href="/orgs/{{ org_name }}/settings/members" class="block px-3 py-1.5 text-sm rounded-md {% if active_section == 'members' %}bg-gray-100 text-gray-900 font-medium{% else %}text-gray-600 hover:text-gray-900 hover:bg-gray-50{% endif %}">Members</a>
        </li>
        <li>
            <a href="/orgs/{{ org_name }}/settings/integrations" class="block px-3 py-1.5 text-sm rounded-md {% if active_section == 'integrations' %}bg-gray-100 text-gray-900 font-medium{% else %}text-gray-600 hover:text-gray-900 hover:bg-gray-50{% endif %}">Integrations</a>
        </li>
        <li>
            <a href="/orgs/{{ org_name }}/settings/compute" class="block px-3 py-1.5 text-sm rounded-md {% if active_section == 'compute' %}bg-gray-100 text-gray-900 font-medium{% else %}text-gray-600 hover:text-gray-900 hover:bg-gray-50{% endif %}">Compute</a>
        </li>
        <li>
            <a href="/orgs/{{ org_name }}/settings/usage" class="block px-3 py-1.5 text-sm rounded-md {% if active_section == 'usage' %}bg-gray-100 text-gray-900 font-medium{% else %}text-gray-600 hover:text-gray-900 hover:bg-gray-50{% endif %}">Usage</a>
        </li>
    </ul>
</nav>
{% endmacro %}

{# Settings page layout wrapper — combines sidebar + content.
   Usage: {% call settings_layout(org_name, "members") %}
            <h2>Members</h2>
            ...content...
          {% endcall %}
#}
{% macro settings_layout(org_name, active_section) %}
<section class="app-container pt-12">
    <h1 class="text-2xl font-bold mb-8">Settings</h1>
    <div class="flex gap-8">
        {{ settings_sidebar(org_name, active_section) }}
        <div class="flex-1 min-w-0">
            {{ caller() }}
        </div>
    </div>
</section>
{% endmacro %}

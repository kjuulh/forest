{% extends "base.html.jinja" %}
{% from "components/ui.html.jinja" import alert %}

{# See signup.html.jinja for the same pattern: builds "?return_to=…" so
   the pending device-login intent survives OAuth/magic-link redirects
   and the cross-link to /signup. #}
{% set rt_query = "" %}
{% if return_to is defined and return_to %}
    {% set rt_query = "?return_to=" ~ return_to|urlencode %}
{% endif %}

{% block content %}
<section class="max-w-md mx-auto px-4 pt-24">
    <h1 class="text-2xl font-bold text-center mb-8">Sign in to Forest</h1>

    {% if error %}
    {{ alert(error, variant="error") }}
    {% endif %}

    <form method="POST" action="/login" class="space-y-4">
        {% if return_to is defined and return_to %}
        <input type="hidden" name="return_to" value="{{ return_to }}">
        {% endif %}
        <div>
            <label for="identifier" class="block text-sm font-medium mb-1">Username or email</label>
            <input
                type="text"
                id="identifier"
                name="identifier"
                value="{{ identifier }}"
                required
                class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900"
                placeholder="alice or alice@example.com">
        </div>

        <div>
            <label for="password" class="block text-sm font-medium mb-1">Password</label>
            <input
                type="password"
                id="password"
                name="password"
                required
                class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900"
                placeholder="Your password">
        </div>

        <div class="flex items-center">
            <input type="checkbox" id="remember_me" name="remember_me" value="on" checked
                   class="h-4 w-4 rounded border-gray-300 text-gray-900 focus:ring-gray-900">
            <label for="remember_me" class="ml-2 text-sm text-gray-600">Remember me</label>
        </div>

        <button
            type="submit"
            class="w-full py-2 bg-gray-900 text-white rounded-md font-medium hover:bg-gray-800">
            Sign in
        </button>
    </form>

    {% if has_google_oauth or has_github_oauth or has_magic_link %}
    <div class="mt-6 flex items-center gap-4">
        <div class="flex-1 border-t border-gray-200"></div>
        <span class="text-sm text-gray-400">or</span>
        <div class="flex-1 border-t border-gray-200"></div>
    </div>

    <div class="mt-4 space-y-3">
        {% if has_google_oauth %}
        <a href="/auth/google{{ rt_query }}"
           class="w-full inline-flex items-center justify-center gap-2 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50">
            <svg class="w-5 h-5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            Continue with Google
        </a>
        {% endif %}

        {% if has_github_oauth %}
        <a href="/auth/github{{ rt_query }}"
           class="w-full inline-flex items-center justify-center gap-2 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.161 22 16.416 22 12c0-5.523-4.477-10-10-10z"/>
            </svg>
            Continue with GitHub
        </a>
        {% endif %}

        {% if has_magic_link %}
        <a href="/auth/magic-link{{ rt_query }}"
           class="w-full inline-flex items-center justify-center gap-2 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50">
            Sign in with email link
        </a>
        {% endif %}
    </div>
    {% endif %}

    <p class="mt-6 text-center text-sm text-gray-600">
        Don't have an account? <a href="/signup{{ rt_query }}" class="font-medium text-gray-900 hover:underline">Create one</a>
    </p>
</section>
{% endblock %}

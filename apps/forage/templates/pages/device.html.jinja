{% extends "base.html.jinja" %}

{% block content %}
<section class="max-w-md mx-auto px-4 pt-24">
    <h1 class="text-2xl font-bold text-center mb-2 text-gray-900 dark:text-gray-100">
        Authorise Forest CLI
    </h1>
    <p class="text-center text-gray-600 dark:text-gray-400 mb-8">
        Approve a sign-in request from the <code class="text-sm bg-gray-100 dark:bg-gray-800 px-1 rounded">forest</code> command line tool.
    </p>

    {% if result == "unconfigured" %}
        <div class="mb-6 p-4 bg-red-50 dark:bg-red-950 border border-red-200 dark:border-red-800 rounded-md text-sm text-red-800 dark:text-red-200">
            <p class="font-medium">Device login isn't configured on this deployment.</p>
            <p class="mt-1">
                This forage instance can't approve CLI device logins yet — the
                operator needs to set <code class="bg-red-100 dark:bg-red-900 px-1 rounded">FOREST_SERVICE_ACCOUNT_API_KEY</code>.
                Until that's done, please sign in to the CLI with
                <code class="bg-red-100 dark:bg-red-900 px-1 rounded">forest auth login --password</code>.
            </p>
        </div>
    {% elif result == "approved" %}
        <div class="mb-6 p-4 bg-green-50 dark:bg-green-950 border border-green-200 dark:border-green-800 rounded-md text-sm text-green-800 dark:text-green-200">
            <p class="font-medium">You're signed in.</p>
            <p class="mt-1">You can close this tab and return to your terminal.</p>
        </div>
    {% elif result == "denied" %}
        <div class="mb-6 p-4 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-md text-sm text-gray-800 dark:text-gray-200">
            <p class="font-medium">Sign-in denied.</p>
            <p class="mt-1">The terminal request was cancelled. You can close this tab.</p>
        </div>
    {% else %}
        {% if error %}
        <div class="mb-6 p-4 bg-red-50 dark:bg-red-950 border border-red-200 dark:border-red-800 rounded-md text-sm text-red-700 dark:text-red-200">
            {{ error }}
        </div>
        {% endif %}

        <div class="mb-6 p-4 bg-amber-50 dark:bg-amber-950/40 border border-amber-200 dark:border-amber-800/60 rounded-md text-sm text-amber-900 dark:text-amber-100">
            <p class="font-medium">Only approve if you started this from your own terminal.</p>
            <p class="mt-1">
                Approving will let the device sign in to Forest as
                <strong>{{ user.username }}</strong>.
            </p>
        </div>

        <form method="POST" action="/device" class="space-y-4">
            <input type="hidden" name="_csrf" value="{{ csrf_token }}">

            <div>
                <label for="user_code" class="block text-sm font-medium mb-1 text-gray-900 dark:text-gray-100">
                    One-time code
                </label>
                <input
                    type="text"
                    id="user_code"
                    name="user_code"
                    value="{{ user_code }}"
                    required
                    autocomplete="off"
                    spellcheck="false"
                    class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 rounded-md text-base font-mono tracking-widest text-center uppercase focus:outline-none focus:ring-2 focus:ring-gray-900 dark:focus:ring-gray-200"
                    placeholder="XXXX-XXXX">
                <p class="mt-2 text-xs text-gray-500 dark:text-gray-400">
                    The code is shown in your terminal where you ran
                    <code class="bg-gray-100 dark:bg-gray-800 px-1 rounded">forest auth login</code>.
                </p>
            </div>

            <div class="flex gap-2">
                <button
                    type="submit"
                    name="action"
                    value="approve"
                    class="flex-1 py-2 bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 rounded-md font-medium hover:bg-gray-800 dark:hover:bg-white">
                    Approve
                </button>
                <button
                    type="submit"
                    name="action"
                    value="deny"
                    class="flex-1 py-2 bg-white dark:bg-gray-900 border border-gray-300 dark:border-gray-700 text-gray-900 dark:text-gray-100 rounded-md font-medium hover:bg-gray-50 dark:hover:bg-gray-800">
                    Deny
                </button>
            </div>
        </form>
    {% endif %}
</section>
{% endblock %}

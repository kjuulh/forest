{% extends "base.html.jinja" %}
{% from "components/settings_sidebar.html.jinja" import settings_layout %}

{% block content %}
{% call settings_layout(org_name, "access") %}
    <div class="space-y-8">
        <div>
            <h2 class="text-lg font-bold mb-2">Auto-invite by email domain</h2>
            <p class="text-sm text-gray-600 mb-4">
                Anyone signing up with a verified email at a domain listed
                below — <strong>and which has passed DNS ownership
                verification</strong> — will see a one-click invite to join
                <strong>{{ org_name }}</strong>. Unverified domains are
                accepted into the list but grant nothing until DNS proves
                you control them.
            </p>

            {% if flash_info %}
                <div class="mb-4 p-3 rounded-md bg-green-50 border border-green-200 text-sm text-green-800">
                    {{ flash_info }}
                </div>
            {% endif %}
            {% if flash_error %}
                <div class="mb-4 p-3 rounded-md bg-red-50 border border-red-200 text-sm text-red-800">
                    {{ flash_error }}
                </div>
            {% endif %}

            {% if is_admin %}
            <form method="POST" action="/orgs/{{ org_name }}/settings/access" class="flex gap-2 mb-6">
                <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                <input
                    type="text"
                    name="domain"
                    placeholder="example.com"
                    required
                    class="flex-1 px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-400"
                >
                <button type="submit" class="px-4 py-2 text-sm font-medium bg-gray-900 text-white rounded-md hover:bg-gray-800">
                    Add domain
                </button>
            </form>
            {% endif %}

            {% if domains %}
            <div class="space-y-3">
                {% for d in domains %}
                <div class="border border-gray-200 rounded-lg p-4">
                    <div class="flex items-center justify-between mb-2">
                        <div class="flex items-center gap-3">
                            <span class="font-mono text-gray-900">{{ d.domain }}</span>
                            {% if d.dns_verified %}
                                <span class="px-2 py-0.5 text-xs rounded-full bg-green-100 text-green-800">DNS verified</span>
                            {% else %}
                                <span class="px-2 py-0.5 text-xs rounded-full bg-yellow-100 text-yellow-800">Awaiting verification</span>
                            {% endif %}
                        </div>
                        {% if is_admin %}
                        <form method="POST" action="/orgs/{{ org_name }}/settings/access/remove" class="inline">
                            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                            <input type="hidden" name="domain" value="{{ d.domain }}">
                            <button type="submit" class="text-sm text-red-600 hover:text-red-800">Remove</button>
                        </form>
                        {% endif %}
                    </div>

                    {% if not d.dns_verified and is_admin %}
                    <div class="mt-2 text-sm text-gray-700">
                        <p class="mb-2">
                            Publish this TXT record, then click Verify:
                        </p>
                        <div class="bg-gray-50 border border-gray-200 rounded-md px-3 py-2 font-mono text-xs overflow-x-auto">
                            <div>name: <span class="text-gray-900">_forest-verify.{{ d.domain }}</span></div>
                            <div>type: <span class="text-gray-900">TXT</span></div>
                            <div>value: <span class="text-gray-900">{{ d.dns_verification_token }}</span></div>
                        </div>
                        <form method="POST" action="/orgs/{{ org_name }}/settings/access/verify" class="mt-3">
                            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                            <input type="hidden" name="domain" value="{{ d.domain }}">
                            <button type="submit" class="px-3 py-1.5 text-sm font-medium bg-gray-900 text-white rounded-md hover:bg-gray-800">
                                Verify DNS
                            </button>
                        </form>
                    </div>
                    {% endif %}
                </div>
                {% endfor %}
            </div>
            {% else %}
            <p class="px-4 py-6 text-sm text-gray-500 text-center border border-gray-200 rounded-lg">
                No domains configured.
            </p>
            {% endif %}
        </div>
    </div>
{% endcall %}
{% endblock %}

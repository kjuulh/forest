{% extends "base.html.jinja" %}

{% block content %}
<section class="max-w-md mx-auto px-4 pt-24">
    <h1 class="text-2xl font-bold mb-4 text-center">Resend verification email</h1>
    <p class="text-gray-600 mb-8 text-center">
        Enter the email you signed up with and we'll send a new verification link.
    </p>

    {% if error %}
    <p class="text-red-600 mb-4">{{ error }}</p>
    {% endif %}

    <form method="post" action="/auth/verify-email/resend" class="space-y-4">
        <div>
            <label for="email" class="block text-sm font-medium text-gray-700">Email</label>
            <input
                type="email"
                id="email"
                name="email"
                value="{{ email | default('') }}"
                required
                class="mt-1 block w-full border-gray-300 rounded shadow-sm focus:border-gray-700 focus:ring-gray-700"
            >
        </div>
        <button type="submit" class="w-full bg-gray-900 text-white py-2 rounded font-medium hover:bg-gray-700">
            Send verification link
        </button>
    </form>
    <p class="text-sm text-gray-400 text-center mt-6">
        <a href="/login" class="font-medium text-gray-900 hover:underline">Back to sign in</a>
    </p>
</section>
{% endblock %}

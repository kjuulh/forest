{% extends "base.html.jinja" %}

{% block content %}
<section class="app-container pt-12">
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-2xl font-bold">Continuous deployment</h1>
        <div class="flex items-center gap-4">
            <a href="/orgs/{{ org_name }}/projects/{{ project_name }}/pipelines" class="text-sm text-gray-500 hover:text-gray-900 flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16"/></svg>
                Pipelines
            </a>
            <a href="/orgs/{{ org_name }}/projects/{{ project_name }}/triggers" class="text-sm text-gray-500 hover:text-gray-900 flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                Triggers
            </a>
            <a href="/orgs/{{ org_name }}/projects/{{ project_name }}/policies" class="text-sm text-gray-500 hover:text-gray-900 flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                Policies
            </a>
        </div>
    </div>

    <release-timeline org="{{ org_name }}" project="{{ project_name }}" csrf="{{ csrf_token }}" username="{{ user.username }}" role="{{ current_role }}"></release-timeline>

    {% if component_versions is defined and component_versions %}
    <div class="mt-12">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-bold">Component versions</h2>
            <a href="/orgs/{{ org_name }}/projects/{{ project_name }}/components" class="text-sm text-gray-500 hover:text-gray-900">View all &rarr;</a>
        </div>
        <div class="border border-gray-200 rounded-lg divide-y divide-gray-200">
            {% for v in component_versions[:5] %}
            <div class="p-3 flex items-center justify-between">
                <div class="flex items-center gap-2">
                    <a href="/components/{{ org_name }}/{{ project_name }}/{{ v.version }}" class="font-medium text-sm hover:underline">v{{ v.version }}</a>
                    {% if v.kind == "binary" %}
                    <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full bg-violet-100 text-violet-700">binary</span>
                    {% else %}
                    <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full bg-cyan-100 text-cyan-700">files</span>
                    {% endif %}
                </div>
                <div class="flex gap-1 flex-wrap">
                    {% for platform in v.platforms %}
                    <span class="text-xs text-gray-400">{{ platform }}</span>
                    {% endfor %}
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}
</section>
<script src="/static/js/components/forage-components.js"></script>
{% endblock %}

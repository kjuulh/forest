{% extends "base.html.jinja" %}
{% from "components/timestamp.html.jinja" import timeago as ts %}
{% from "components/ui.html.jinja" import badge, kind_badge, visibility_badge, tool_shape_badge, empty_state, code_block, pretty_json_block %}

{# Project Overview — the canonical home (specs/features/008).
   Shape-aware: when the project has a 1:1 canonical component, fold its
   shape/tool/manifest data into the page. When the project has no
   releases, render only the centered Get-started panel — no empty cards.
#}

{% set is_tool = summary and (summary.shape == "hybrid" or summary.shape == "tool_binary" or summary.shape == "tool_external") %}
{% set show_get_started = not comp_versions and not readme_html %}

{% block content %}
<section class="app-container pt-12 pb-8">
    {# ── Header ─────────────────────────────────────────────────── #}
    <div class="flex items-start justify-between mb-6 gap-4">
        <div class="min-w-0">
            <h1 class="text-2xl font-bold flex items-center gap-2 flex-wrap">
                <span class="text-gray-400 font-mono text-base">{{ org_name }}/</span>{{ project_name }}
            </h1>
            {% if summary and summary.description %}
            <p class="mt-1 text-gray-600">{{ summary.description }}</p>
            {% endif %}
            {# Project-level header keeps only visibility — component
               version/shape/tool pills belong on the component detail page,
               not the project Overview. #}
            {% if summary and summary.visibility %}
            <div class="mt-2 flex items-center gap-2 flex-wrap">
                {{ visibility_badge(summary.visibility) }}
            </div>
            {% endif %}
        </div>
        {# ── Install dropdown (GitHub "Code" button) ──────────────────
           Native <details>/<summary> so it's keyboard-accessible and works
           without JS. The panel is positioned absolutely so it overlays
           page content; the parent <details> has class="relative". #}
        {% if summary %}
        <details class="relative shrink-0 group">
            <summary class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-green-600 text-white text-sm font-medium rounded-md hover:bg-green-700 cursor-pointer list-none select-none">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                {% if is_tool %}Install{% else %}Add{% endif %}
                <svg class="w-3 h-3 ml-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="absolute right-0 mt-2 w-96 max-w-[calc(100vw-2rem)] bg-white border border-gray-200 rounded-md shadow-lg z-10 p-4 space-y-3">
                {% if is_tool %}
                <div>
                    <p class="text-xs font-bold text-gray-500 uppercase tracking-wide mb-1.5">Install globally</p>
                    {{ code_block("forest global add " ~ summary.organisation ~ "/" ~ summary.name, copyable=true, id="install-cmd-latest") }}
                </div>
                {% if summary.latest_version %}
                <div>
                    <p class="text-xs font-bold text-gray-500 uppercase tracking-wide mb-1.5">Pin to a specific version</p>
                    {{ code_block("forest global add " ~ summary.organisation ~ "/" ~ summary.name ~ "@" ~ summary.latest_version, copyable=true, id="install-cmd-pinned") }}
                </div>
                {% endif %}
                {% else %}
                <div>
                    <p class="text-xs font-bold text-gray-500 uppercase tracking-wide mb-1.5">Add to a project</p>
                    {% if summary.latest_version %}
                    {{ code_block("forest components add " ~ summary.organisation ~ "/" ~ summary.name ~ "@" ~ summary.latest_version, copyable=true, id="add-cmd") }}
                    {% else %}
                    {{ code_block("forest components add " ~ summary.organisation ~ "/" ~ summary.name, copyable=true, id="add-cmd") }}
                    {% endif %}
                </div>
                {% endif %}
            </div>
        </details>
        {% endif %}
    </div>

    {% if show_get_started %}
    {# ── Get-started panel (only when project is empty out-of-box) ─ #}
    <div class="max-w-md mx-auto text-center border border-gray-200 rounded-lg p-8 mt-6">
        <h2 class="text-lg font-bold mb-2">Publish your first version</h2>
        <p class="text-sm text-gray-600 mb-4">Run <code class="text-xs bg-gray-100 px-1.5 py-0.5 rounded">forest publish</code> from the project directory to ship the first release.</p>
        <div class="text-left">
            {{ code_block("forest publish", copyable=true, id="get-started-cmd", class="text-xs") }}
        </div>
    </div>
    {% else %}

    {# ── Releases swimlane (top, just below the header) ──────────────
       Compact view; full timeline on the Releases tab. Sits above the
       README/sidebar grid so it spans the full width when the timeline
       has lanes. #}
    {% if project_has_timeline %}
    <div class="mb-10">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-bold">Recent releases</h2>
            <a href="/orgs/{{ org_name }}/projects/{{ project_name }}/releases" class="text-sm text-gray-500 hover:text-gray-900">View all &rarr;</a>
        </div>
        <release-timeline org="{{ org_name }}" project="{{ project_name }}" csrf="{{ csrf_token }}" username="{{ user.username }}" role="{{ current_role }}" limit="3"></release-timeline>
    </div>
    <script src="/static/js/components/forage-components.js"></script>
    {% endif %}

    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        <div class="md:col-span-3">
            {# ── README (main content, GitHub-style) ───────────────── #}
            {% if readme_html %}
            <div class="prose prose-sm max-w-none">
                {{ readme_html | safe }}
            </div>
            {% endif %}
        </div>

        {# ── Sidebar ────────────────────────────────────────────────── #}
        <div class="md:col-span-1">
            <div class="space-y-6">
                {# Project-level sidebar: About / Components / Metadata.
                   Component-specific surfaces (version / kind / shape /
                   Distribution / manifest) belong on the component detail
                   page, not the project Overview. Click a Components row
                   below to drill into them. #}

                {# ── Components (compact, GitHub-Releases-summary style) ──
                   The project's published artefacts. Latest first with a
                   "latest" pill; top 3 with a "+ N more" link to the full
                   Releases tab. #}
                {% if comp_versions %}
                <div>
                    <h3 class="text-sm font-bold mb-2 flex items-center gap-2">
                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                        Components
                    </h3>
                    <ul class="space-y-2 text-sm">
                        {% for v in comp_versions[:3] %}
                        <li class="flex items-center justify-between gap-2">
                            <a href="/components/{{ org_name }}/{{ project_name }}/{{ v.version }}" class="font-medium text-gray-700 hover:text-gray-900 hover:underline">v{{ v.version }}</a>
                            <div class="flex items-center gap-1.5 shrink-0">
                                {% if loop.index == 1 %}{{ badge("latest", variant="green") }}{% endif %}
                            </div>
                        </li>
                        {% endfor %}
                    </ul>
                    {% if comp_versions | length > 3 %}
                    <a href="/orgs/{{ org_name }}/projects/{{ project_name }}/releases" class="block mt-2 text-xs text-gray-500 hover:text-gray-900">
                        + {{ comp_versions | length - 3 }} more &rarr;
                    </a>
                    {% endif %}
                </div>
                {% endif %}

                {# Metadata renders only when there's at least one item —
                   clean empty-state policy from spec 008. #}
                {% if summary and (summary.created_at or summary.updated_at or summary.contracts) %}
                <div>
                    <h3 class="text-sm font-bold mb-2">Metadata</h3>
                    <dl class="text-sm space-y-2">
                        {% if summary.created_at %}
                        <div>
                            <dt class="text-gray-500">Created</dt>
                            <dd>{{ ts(summary.created_at) }}</dd>
                        </div>
                        {% endif %}
                        {% if summary.updated_at %}
                        <div>
                            <dt class="text-gray-500">Updated</dt>
                            <dd>{{ ts(summary.updated_at) }}</dd>
                        </div>
                        {% endif %}
                        {% if summary.contracts %}
                        <div>
                            <dt class="text-gray-500">Contracts</dt>
                            <dd class="flex gap-1.5 flex-wrap mt-1">
                                {% for contract in summary.contracts %}
                                {{ badge(contract) }}
                                {% endfor %}
                            </dd>
                        </div>
                        {% endif %}
                    </dl>
                </div>
                {% endif %}
            </div>
        </div>
    </div>

    {# Manifest, Distribution, version/shape/kind details all live on the
       component detail page now — drill in from the Components list. #}

    {% endif %}{# /show_get_started #}
</section>
{% endblock %}

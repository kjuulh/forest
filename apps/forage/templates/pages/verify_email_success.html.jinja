{% extends "base.html.jinja" %}

{% block content %}
<section class="max-w-md mx-auto px-4 pt-24 text-center">
    <h1 class="text-2xl font-bold mb-4">Email verified</h1>
    <p class="text-gray-600 mb-8">
        <strong>{{ email }}</strong> has been verified. You can now sign in.
    </p>
    <p>
        <a href="/login" class="inline-block bg-gray-900 text-white px-6 py-2 rounded font-medium hover:bg-gray-700">
            Log in now
        </a>
    </p>
</section>
{% endblock %}

# Forest server gRPC endpoint
FOREST_SERVER_URL=http://localhost:4040

# HTTP port (default: 3000)
# PORT=3001

# PostgreSQL connection (required for integrations, optional for sessions)
DATABASE_URL=postgresql://forageuser:foragepassword@localhost:5433/forage

# Encryption key for integration configs at rest (32+ chars recommended)
# INTEGRATION_ENCRYPTION_KEY=your-secret-key-here

# Slack OAuth (for Slack integration setup)
# SLACK_CLIENT_ID=your-slack-client-id
# SLACK_CLIENT_SECRET=your-slack-client-secret

# Service token (PAT) for forest-server notification listener auth
# FORAGE_SERVICE_TOKEN=forage-secret

# NATS JetStream for durable notification delivery (optional, falls back to direct dispatch)
# NATS_URL=nats://localhost:4223

# Public URL for OAuth callbacks (default: http://localhost:{PORT})
# FORAGE_HOST=https://forage.sh

# Google OAuth
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth
# GITHUB_APP_CLIENT_ID=your-github-app-client-id
# GITHUB_APP_CLIENT_SECRET=your-github-app-client-secret

# Service account key for Forest (trusted service-to-service auth)
# FOREST_SERVICE_ACCOUNT_API_KEY=your-shared-secret

# SMTP for magic link emails (Mailpit in dev: localhost:1025, no auth)
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_FROM=noreply@forage.dev
# SMTP_TLS=false  # set to false for Mailpit/dev (default: true)
# Mailpit web UI: http://localhost:8025

# OpenTelemetry — opt-in. Setting OTEL_SERVICE_NAME enables OTLP export of
# traces, logs, and metrics via canopy-otel. Unset ⇒ pretty stdout fmt only.
# Endpoint defaults to http://localhost:4318 (OTLP/HTTP) per the OTEL spec.
# OTEL_SERVICE_NAME=forage-server
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# OTEL_EXPORTER_OTLP_HEADERS=api-key=...
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=dev,service.version=0.1.0

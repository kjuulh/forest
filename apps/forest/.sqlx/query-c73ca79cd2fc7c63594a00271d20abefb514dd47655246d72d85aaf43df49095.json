  "query": "\n            SELECT DISTINCT d.id, d.name, d.environment\n            FROM destinations d\n            LEFT JOIN environments e ON d.environment_id = e.id\n            WHERE d.organisation = $3\n              AND (d.name = ANY($1) OR e.name = ANY($2))\n            ",

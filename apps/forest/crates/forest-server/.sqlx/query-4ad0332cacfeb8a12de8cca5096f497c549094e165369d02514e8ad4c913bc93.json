{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT o.id, o.name, o.created_at, o.updated_at, om.role\n            FROM organisations o\n            JOIN organisation_members om ON om.organisation_id = o.id\n            WHERE om.user_id = $1\n              AND ($2::text IS NULL OR om.role = $2)\n            ORDER BY o.name ASC\n            ",

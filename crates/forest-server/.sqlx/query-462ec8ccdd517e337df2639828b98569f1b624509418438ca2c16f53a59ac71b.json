  "query": "SELECT\n                rs.release_id,\n                rs.release_intent_id,\n                rs.destination_id,\n                rs.status,\n                d.name as destination_name,\n                d.environment as destination_environment\n             FROM release_states rs\n             JOIN destinations d ON rs.destination_id = d.id\n             WHERE rs.release_intent_id = $1",

{
  "env": "dev",
  "destination": "infrastructure-dev.*",
  "destination_type": "forest/terraform@1",
  "component": {
    "organisation": "forest-contrib",
    "name": "rust-persistent-service",
    "source": {
      "Local": "../../components/forest-contrib/rust_persistent_service"
    }
  },
  "config": {
    "environment": [
      {
        "key": "RUST_LOG",
        "value": "my_service=debug,info"
      },
      {
        "key": "RUST_LOG",
        "value": "debug"
      }
    ],
    "replicas": 3,
    "name": "service-example",
    "health_checks": {
      "live": {
        "http": {
          "port": 3001,
          "path": "/"
        }
      }
    },
    "ports": [
      {
        "external": true,
        "port": 3000,
        "name": "external"
      },
      {
        "port": 3001,
        "name": "internal"
      },
      {
        "subdomain": "grpc",
        "external": true,
        "port": 4000,
        "name": "grpc_external"
      },
      {
        "name": "grpc_internal",
        "port": 4001
      }
    ]
  }
}
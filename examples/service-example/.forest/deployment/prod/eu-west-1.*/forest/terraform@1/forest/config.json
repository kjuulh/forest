{
  "env": "prod",
  "destination": "eu-west-1.*",
  "destination_type": "forest/terraform@1",
  "component": {
    "organisation": "forest-contrib",
    "name": "rust-persistent-service",
    "source": {
      "Local": "../../components/forest-contrib/rust_persistent_service"
    }
  },
  "config": {
    "replicas": 10,
    "name": "service-example",
    "environment": [
      {
        "key": "RUST_LOG",
        "value": "my_service=debug,info"
      },
      {
        "key": "RUST_LOG",
        "value": "info"
      }
    ],
    "health_checks": {
      "live": {
        "http": {
          "path": "/",
          "port": 3001
        }
      }
    },
    "ports": [
      {
        "name": "external",
        "external": true,
        "port": 3000
      },
      {
        "name": "internal",
        "port": 3001
      },
      {
        "external": true,
        "port": 4000,
        "name": "grpc_external",
        "subdomain": "grpc"
      },
      {
        "name": "grpc_internal",
        "port": 4001
      }
    ]
  }
}
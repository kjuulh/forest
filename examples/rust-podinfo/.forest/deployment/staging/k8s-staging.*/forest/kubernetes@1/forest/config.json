{
  "env": "staging",
  "destination": "k8s-staging.*",
  "destination_type": "forest/kubernetes@1",
  "component": {
    "organisation": "forest-contrib",
    "name": "rust-service",
    "source": {
      "Local": "../rust-service-component"
    }
  },
  "config": {
    "resources": {
      "requests": {
        "memory": "256Mi",
        "cpu": "250m"
      },
      "limits": {
        "memory": "512Mi",
        "cpu": "500m"
      }
    },
    "environment": [
      {
        "value": "rust_podinfo=info",
        "key": "RUST_LOG"
      },
      {
        "key": "RUST_LOG",
        "value": "rust_podinfo=info"
      },
      {
        "key": "PODINFO_ENV",
        "value": "staging"
      }
    ],
    "name": "rust-podinfo",
    "replicas": 2,
    "image": "registry.example.com/rawpotion/rust-podinfo",
    "health_checks": {
      "readiness": {
        "path": "/readyz",
        "port": 8081
      },
      "liveness": {
        "port": 8081,
        "path": "/healthz"
      }
    },
    "ports": [
      {
        "name": "http",
        "port": 8080,
        "external": true
      },
      {
        "name": "internal",
        "port": 8081
      }
    ]
  }
}